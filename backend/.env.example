# Server
PORT=3001
NODE_ENV=development

# Frontend
# FRONTEND_URL - כתובת יחידה, משמשת גם לבניית קישורי מעקב בהודעות SMS/מייל.
# CORS_ORIGIN - לכתובות נוספות המורשות ב-CORS בלבד (אפשר כמה, מופרדות בפסיק),
# למשל אם יש גם דומיין מותאם אישית בנוסף ל-Netlify.
# https://david-move.netlify.app כבר מותר תמיד כברירת מחדל בקוד (ר' server.ts) -
# אין חובה להגדיר את המשתנים האלו, אבל מומלץ להגדיר FRONTEND_URL בפרודקשן
# לדומיין האמיתי של הלקוחות (כדי שקישורי המעקב בהודעות יהיו נכונים).
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=

# MongoDB
MONGO_URI=mongodb://localhost:27017/david-move

# OpenAI
OPENAI_API_KEY=sk-...

# Email (Gmail App Password) - used for order confirmation + move reminders
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Twilio (SMS + WhatsApp reminders) - optional, reminders are skipped/logged if unset
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=+1XXXXXXXXXX

# Admin API key - required header (x-admin-key) to access admin/PII endpoints
# (moving estimates list/status, customers, analytics, AI insights, tracking updates).
# Must be set in production - if unset, these endpoints run unprotected with a warning.
ADMIN_API_KEY=change-me-to-a-random-secret

# JWT secret - signs the login token for business accounts (multi-tenant SaaS
# accounts, /api/auth/signup + /api/auth/login). Required for those endpoints to
# work at all (they return 503 without it) - use a long random string, and never
# reuse the same value between environments (dev/staging/production).
JWT_SECRET=change-me-to-a-long-random-secret

# Green Invoice (מורנינג) - ספק חשבוניות חיצוני, אופציונלי.
# ברירת המחדל של האפליקציה היא הפקת חשבונית/קבלה עצמאית ("built_in") ללא כל ספק
# חיצוני וללא תשלום - ר' מסך "הגדרות עסק וחשבונות" בדשבורד הניהול. ניתן להתחבר
# ל-Green Invoice משם (שומר את המפתחות ב-DB) במקום כאן - זה נוח יותר מעריכת
# משתני סביבה בפרודקשן. משתני הסביבה כאן משמשים רק כגיבוי/ברירת מחדל אם לא
# הוגדר חיבור דרך מסך ההגדרות.
# הרשמה: https://www.greeninvoice.co.il -> הגדרות -> API. יש לבדוק תחילה מול sandbox.
GREEN_INVOICE_API_KEY=
GREEN_INVOICE_API_SECRET=
GREEN_INVOICE_ENV=sandbox
