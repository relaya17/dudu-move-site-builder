# Server
PORT=3001
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/david-move

# OpenAI
OPENAI_API_KEY=sk-...

# Email (Gmail App Password) - used for order confirmation + move reminders
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Twilio (SMS + WhatsApp reminders) - optional, reminders are skipped/logged if unset
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=+1XXXXXXXXXX

# Admin API key - required header (x-admin-key) to update tracking stage/location
ADMIN_API_KEY=change-me-to-a-random-secret
