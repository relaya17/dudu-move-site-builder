# Backend API URL (leave empty to use Vite proxy in dev)
VITE_API_URL=

# Firebase config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Admin key - used both as the admin panel login password and as the x-admin-key
# header sent to protected backend endpoints. Must match backend's ADMIN_API_KEY.
VITE_ADMIN_API_KEY=change-me-to-a-random-secret
